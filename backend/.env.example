# RX PRO Backend Configuration
# COPIA este archivo como .env y cambia los valores

PORT=3001

# Genera una clave aleatoria larga (mínimo 64 caracteres)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA

# Clave para acceder a los endpoints de administración
# Cámbiala por algo seguro y único
ADMIN_SECRET=RX-ADMIN-CAMBIA-ESTO-2024

# URL del frontend (para CORS)
# En desarrollo: http://localhost:5500
# En producción: https://tu-app.netlify.app
CORS_ORIGIN=http://localhost:5500

# URL de conexión a PostgreSQL (Supabase)
# La encuentras en: Supabase → tu proyecto → Settings → Database → Connection string → URI
# IMPORTANTE: Reemplaza [YOUR-PASSWORD] con tu contraseña real
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Entorno (development | production)
NODE_ENV=production
