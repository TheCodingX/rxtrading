# RX PRO Backend Configuration
# COPIA este archivo como .env y cambia los valores

PORT=3001

# Genera una clave aleatoria larga (minimo 64 caracteres)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA

# Clave para acceder a los endpoints de administracion
# Cambiala por algo seguro y unico
ADMIN_SECRET=RX-ADMIN-CAMBIA-ESTO-2024

# URL del frontend (para CORS y redirects de pago)
# En desarrollo: http://localhost:5500
# En produccion: https://rxtrading.net
CORS_ORIGIN=https://rxtrading.net
FRONTEND_URL=https://rxtrading.net

# URL del backend (para webhooks de pago)
BACKEND_URL=https://rxtrading-1.onrender.com

# URL de conexion a PostgreSQL (Supabase)
# La encuentras en: Supabase -> tu proyecto -> Settings -> Database -> Connection string -> URI
# IMPORTANTE: Reemplaza [YOUR-PASSWORD] con tu contrasena real
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Entorno (development | production)
NODE_ENV=production

# ═══════════════════════════════════════
# STRIPE (pagos con tarjeta)
# ═══════════════════════════════════════
STRIPE_SECRET_KEY=rk_test_XXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXX

# ═══════════════════════════════════════
# MERCADOPAGO
# ═══════════════════════════════════════
MP_ACCESS_TOKEN=TEST-XXXXXXX

# ═══════════════════════════════════════
# USDT TRC20
# ═══════════════════════════════════════
USDT_WALLET=ETf8gN5Zg1RTibnXv1Moixk8ksnGmLZd76uzgR4RCTG7
