# ═══════════════════════════════════════════════════════════════
#  RX TRADING — Backend Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════

# ═══ REQUIRED ═══

# JWT signing secret (min 32 chars, high entropy)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# PostgreSQL connection string (Render / Supabase / self-hosted)
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=

# ═══ REQUIRED IN PRODUCTION ═══

# Broker encryption master key (AES-256-GCM, 32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if lost, ALL encrypted broker API keys become unrecoverable
BROKER_MASTER_KEY=

# Salt for IP address hashing (GDPR compliant logging)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
IP_SALT=change_me_random_string

# Admin secret (required in x-admin-secret header for /api/admin/* endpoints)
ADMIN_SECRET=

# ═══ PAYMENT PROVIDERS (at least one required) ═══

# Stripe (card payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MercadoPago (LATAM)
MP_ACCESS_TOKEN=APP_USR-...
# Webhook signature secret (from MP dashboard → Notifications → Webhooks)
MP_WEBHOOK_SECRET=

# NOWPayments (crypto / USDT)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# USDT TRC20 manual wallet (fallback)
USDT_WALLET=

# ═══ OPTIONAL (with defaults) ═══

# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=production

# CORS allowed origins (comma-separated, must be https://)
CORS_ORIGIN=https://rxtrading.net,https://www.rxtrading.net

# Frontend URL (for payment success/cancel redirects)
FRONTEND_URL=https://rxtrading.net

# Backend URL (for webhook callbacks in payment provider config)
BACKEND_URL=https://rxtrading-1.onrender.com

# Binance mode: 'true' = testnet, unset/'false' = mainnet
# IMPORTANT: Use testnet keys ONLY when true, mainnet keys ONLY when unset
# BINANCE_TESTNET=true

# DB pool config (default: 10 max, bump for high concurrency)
DB_POOL_MAX=10

# SSL strict mode for DB connection ('true' rejects unauthorized certs)
# Default false in production for managed DBs with self-signed certs (Render)
DB_SSL_STRICT=false

# APEX pair universe (comma-separated USDT pairs)
# Default: APEX v42 PRO+ 15-pair universe
# APEX_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,...

# Trust proxy hops (Render uses 1, AWS CloudFront + ALB = 2+)
# TRUST_PROXY=1
